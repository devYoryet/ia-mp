# Copiar a .env y completar. NO versionar .env.

# --- Base de datos de origen (servidor clasico) ---
MYSQL_HOST=10.0.0.69
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=licitaciones_diarias_total_farma
# Catálogo primario de pactivos (0001_td_oc.Base) y secundario: la base que
# contiene la tabla `diccionario` de clasificación (la misma del legacy).
MYSQL_DB_CATALOGO=0001_td_oc
MYSQL_DB_DICCIONARIO=licitaciones_diarias_total_farma

# --- API de Anthropic ---
ANTHROPIC_API_KEY=
# claude-haiku-4-5 (barato) · claude-sonnet-4-6 · claude-opus-4-7 (máx. precisión)
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Parámetros del worker ---
# MODO=test: compara IA vs humanos sin tocar producción (empezar siempre aquí).
# MODO=produccion: escribe la clasificación en compra_agil.
MODO=test
INTERVALO_SEGUNDOS=300
LOTE_MAX=200
# Solo en MODO=produccion: si true, descarta automáticamente (estado_gestor=0)
# lo que la IA marque sin interés con confianza >= 0.9.
AUTO_APLICAR_DESCARTES=false
# Etapa 0: veces mínimas que un código de Item debe haber aparecido, siempre
# descartado, para descartarlo automáticamente sin llamar a Claude.
DESCARTE_ITEM_MIN_VISTAS=20
# Etapa 1: soporte mínimo para confiar en un DESCARTE del histórico. Por debajo,
# la fila no se descarta por histórico y sigue a las etapas siguientes.
UMBRAL_DESCARTE_HISTORICO=5

# --- Presupuesto (para el panel de costo) ---
BUDGET_USD=350
FILAS_MES_ESTIMADO=350000
